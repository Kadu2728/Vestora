ENVIRONMENT=development

# Local dev: sqlite:///./vestora.db
# Produção (Neon): postgresql+psycopg2://user:password@host/dbname?sslmode=require
DATABASE_URL=sqlite:///./vestora.db

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-32-byte-secret

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000,https://vestora.vercel.app

TRIAL_DURATION_DAYS=14

MARKET_DATA_BASE_URL=https://brapi.dev/api
MARKET_DATA_API_TOKEN=
MARKET_DATA_CACHE_TTL_SECONDS=60
